{
  "name": "@cinatra-ai/linkedin-connector",
  "version": "0.1.3",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "src",
    "!src/__tests__"
  ],
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./register": "./src/register.ts",
    "./deps": "./src/deps.ts",
    "./settings-page": "./src/settings-page.tsx",
    "./setup-page": "./src/setup-page.tsx",
    "./mcp-handlers": "./src/mcp/handlers.ts",
    "./mcp-module": "./src/mcp/module.ts"
  },
  "types": "./src/index.ts",
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@cinatra-ai/sdk-extensions": "*",
    "@cinatra-ai/sdk-ui": "*"
  },
  "peerDependenciesMeta": {
    "@cinatra-ai/sdk-extensions": {
      "optional": true
    },
    "@cinatra-ai/sdk-ui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "8.61.0",
    "eslint": "10.4.1",
    "typescript": "5.9.3"
  },
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "connector",
    "displayName": "LinkedIn",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/social-media-connector",
        "kind": "connector",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "exact",
          "version": "0.1.1"
        },
        "requirement": "required"
      },
      {
        "packageName": "@cinatra-ai/linkedin-oauth-connector",
        "kind": "connector",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "exact",
          "version": "0.1.1"
        },
        "requirement": "required"
      }
    ],
    "serverEntry": "./register",
    "requestedHostPorts": [
      "authSession",
      "nango",
      "capabilities"
    ],
    "sdkAbiRange": "^2"
  },
  "scripts": {
    "lint": "eslint . --no-inline-config"
  }
}
